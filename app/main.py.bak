import json
import tempfile
from fastapi import FastAPI, File, Form, UploadFile
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import HTMLResponse
from .ocr import ocr_image
from .validation import validate_label

app = FastAPI(title="Alcohol Label Verification Prototype")
app.add_middleware(CORSMiddleware, allow_origins=["*"], allow_methods=["*"], allow_headers=["*"])

HTML = """
<!doctype html><html><head><title>Label Verifier</title>
<style>body{font-family:Arial;margin:32px;max-width:1100px} input,textarea,button{width:100%;margin:8px 0;padding:10px} table{border-collapse:collapse;width:100%;margin-top:16px} td,th{border:1px solid #ccc;padding:8px;text-align:left}.match{background:#e7f7e7}.mismatch{background:#ffe8e8}.review{background:#fff6d5}</style>
</head><body>
<h1>Alcohol Label Verification Prototype</h1>
<p>Upload a label image, or paste OCR text for faster testing.</p>
<label>Application JSON</label>
<textarea id="appdata" rows="8">{"brand_name":"OLD TOM DISTILLERY","class_type":"Kentucky Straight Bourbon Whiskey","alcohol_content":45,"net_contents":"750 mL"}</textarea>
<label>Label image</label><input type="file" id="image">
<label>Optional pasted label text, bypasses OCR</label><textarea id="labeltext" rows="8"></textarea>
<button onclick="run()">Validate Label</button><div id="out"></div>
<script>
async function run(){
 const fd=new FormData();
 fd.append('application_json', document.getElementById('appdata').value);
 fd.append('label_text', document.getElementById('labeltext').value);
 const file=document.getElementById('image').files[0]; if(file) fd.append('image', file);
 const res=await fetch('/validate',{method:'POST',body:fd});
 const data=await res.json();
 let html='<h2>Results</h2><table><tr><th>Field</th><th>Application</th><th>Label</th><th>Status</th><th>Confidence</th><th>Rule</th></tr>';
 for(const r of data.results){html+=`<tr class="${r.status}"><td>${r.field}</td><td>${r.application??''}</td><td>${r.label??''}</td><td>${r.status}</td><td>${r.confidence}</td><td>${r.rule}</td></tr>`}
 html+='</table><pre>'+JSON.stringify(data.summary,null,2)+'</pre>'; document.getElementById('out').innerHTML=html;
}
</script></body></html>
"""

@app.get("/", response_class=HTMLResponse)
def index():
    return HTML

@app.post("/validate")
async def validate(application_json: str = Form(...), label_text: str = Form(""), image: UploadFile | None = File(None)):
    application = json.loads(application_json)
    text = label_text.strip()
    if not text and image is not None:
        suffix = image.filename.split('.')[-1] if image.filename else 'png'
        with tempfile.NamedTemporaryFile(delete=False, suffix=f'.{suffix}') as tmp:
            tmp.write(await image.read())
            text = ocr_image(tmp.name)
    if not text:
        return {"error": "Provide an image or pasted label text."}
    return validate_label(application, text)

@app.post("/batch-validate")
async def batch_validate(payload: list[dict]):
    # Payload shape: [{"application": {...}, "label_text": "..."}]
    return [validate_label(item["application"], item["label_text"]) for item in payload]
